# Terminal color setup
if [[ $COLORTERM = gnome-* && $TERM = xterm ]] && infocmp gnome-256color >/dev/null 2>&1; then
  export TERM=gnome-256color
elif infocmp xterm-256color >/dev/null 2>&1; then
  export TERM=xterm-256color
fi

if tput setaf 1 &> /dev/null; then
  tput sgr0
  if [[ $(tput colors) -ge 256 ]] 2>/dev/null; then
    MAGENTA=$(tput setaf 125)
    ORANGE=$(tput setaf 166)
    GREEN=$(tput setaf 64)
    PURPLE=$(tput setaf 61)
    WHITE=$(tput setaf 244)
    PINK=$(tput setaf $(fromhex ff6c8c))
    YELLOW=$(tput setaf $(fromhex ffee6c))
    BLUE=$(tput setaf $(fromhex 6cacff))
  else
    MAGENTA=$(tput setaf 5)
    ORANGE=$(tput setaf 4)
    GREEN=$(tput setaf 2)
    PURPLE=$(tput setaf 1)
    WHITE=$(tput setaf 7)
    PINK=$MAGENTA
    YELLOW=$(tput setaf 3)
    BLUE=$(tput setaf 4)
  fi
  BOLD=$(tput bold)
  RESET=$(tput sgr0)
else
  MAGENTA="\033[1;31m"
  ORANGE="\033[1;33m"
  GREEN="\033[1;32m"
  PURPLE="\033[1;35m"
  WHITE="\033[1;37m"
  PINK="\033[1;31m"
  YELLOW="\033[1;33m"
  BLUE="\033[1;34m"
  BOLD=""
  RESET="\033[m"
fi

export MAGENTA ORANGE GREEN PURPLE WHITE PINK YELLOW BLUE BOLD RESET
