export NVM_DIR="$HOME/.nvm"
export ZSH="$HOME/.oh-my-zsh"
export EDITOR="nano"
export TSH_DIR="$HOME/.terminally-chill-shell"

# Lazy-load nvm: only sources nvm on first use of nvm/node/npm/npx/yarn/netlify.
# Each wrapper is fully self-contained — no external helpers — so it works
# in subshells and Claude Code shell snapshots where only the individual
# function definition may be captured.
#
# SC1091 is disabled throughout because nvm.sh is an external runtime file
# installed in the user's home directory — shellcheck cannot follow it at
# lint time and there is no workaround.
# shellcheck disable=SC1091
nvm() {
  unset -f nvm node npm npx yarn netlify ntl 2>/dev/null
  [ -s "${NVM_DIR:-$HOME/.nvm}/nvm.sh" ] && \. "${NVM_DIR:-$HOME/.nvm}/nvm.sh"
  [ -s "${NVM_DIR:-$HOME/.nvm}/bash_completion" ] && \. "${NVM_DIR:-$HOME/.nvm}/bash_completion"
  nvm "$@"
}
# shellcheck disable=SC1091
node() {
  unset -f nvm node npm npx yarn netlify ntl 2>/dev/null
  [ -s "${NVM_DIR:-$HOME/.nvm}/nvm.sh" ] && \. "${NVM_DIR:-$HOME/.nvm}/nvm.sh"
  command node "$@"
}
# shellcheck disable=SC1091
npm() {
  unset -f nvm node npm npx yarn netlify ntl 2>/dev/null
  [ -s "${NVM_DIR:-$HOME/.nvm}/nvm.sh" ] && \. "${NVM_DIR:-$HOME/.nvm}/nvm.sh"
  command npm "$@"
}
# shellcheck disable=SC1091
npx() {
  unset -f nvm node npm npx yarn netlify ntl 2>/dev/null
  [ -s "${NVM_DIR:-$HOME/.nvm}/nvm.sh" ] && \. "${NVM_DIR:-$HOME/.nvm}/nvm.sh"
  command npx "$@"
}
# shellcheck disable=SC1091
yarn() {
  unset -f nvm node npm npx yarn netlify ntl 2>/dev/null
  [ -s "${NVM_DIR:-$HOME/.nvm}/nvm.sh" ] && \. "${NVM_DIR:-$HOME/.nvm}/nvm.sh"
  command yarn "$@"
}
# shellcheck disable=SC1091
netlify() {
  unset -f nvm node npm npx yarn netlify ntl 2>/dev/null
  [ -s "${NVM_DIR:-$HOME/.nvm}/nvm.sh" ] && \. "${NVM_DIR:-$HOME/.nvm}/nvm.sh"
  command netlify "$@"
}
# shellcheck disable=SC1091
ntl() {
  unset -f nvm node npm npx yarn netlify ntl 2>/dev/null
  [ -s "${NVM_DIR:-$HOME/.nvm}/nvm.sh" ] && \. "${NVM_DIR:-$HOME/.nvm}/nvm.sh"
  command ntl "$@"
}
