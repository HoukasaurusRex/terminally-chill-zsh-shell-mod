export NVM_DIR="$HOME/.nvm"
export ZSH="$HOME/.oh-my-zsh"
export EDITOR="nano"
export TSH_DIR="$HOME/.terminally-chill-shell"

# Lazy-load nvm: only sources nvm on first use of nvm/node/npm/npx/yarn/netlify.
# Each wrapper is self-contained so it works in subshells where _load_nvm
# might not be inherited.
#
# SC1091 is disabled throughout because nvm.sh is an external runtime file
# installed in the user's home directory — shellcheck cannot follow it at
# lint time and there is no workaround.
_nvm_cmds="nvm node npm npx yarn netlify ntl"
# shellcheck disable=SC1091,SC2086
_load_nvm() {
  unset -f _load_nvm $_nvm_cmds
  [ -s "${NVM_DIR:-$HOME/.nvm}/nvm.sh" ] && \. "${NVM_DIR:-$HOME/.nvm}/nvm.sh"
  [ -s "${NVM_DIR:-$HOME/.nvm}/bash_completion" ] && \. "${NVM_DIR:-$HOME/.nvm}/bash_completion"
}
# shellcheck disable=SC1091,SC2086
_nvm_fallback() { unset -f $_nvm_cmds; [ -s "${NVM_DIR:-$HOME/.nvm}/nvm.sh" ] && \. "${NVM_DIR:-$HOME/.nvm}/nvm.sh"; }
nvm()     { _load_nvm 2>/dev/null || _nvm_fallback; nvm "$@"; }
node()    { _load_nvm 2>/dev/null || _nvm_fallback; command node "$@"; }
npm()     { _load_nvm 2>/dev/null || _nvm_fallback; command npm "$@"; }
npx()     { _load_nvm 2>/dev/null || _nvm_fallback; command npx "$@"; }
yarn()    { _load_nvm 2>/dev/null || _nvm_fallback; command yarn "$@"; }
netlify() { _load_nvm 2>/dev/null || _nvm_fallback; command netlify "$@"; }
ntl()     { _load_nvm 2>/dev/null || _nvm_fallback; command ntl "$@"; }
