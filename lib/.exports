export NVM_DIR="$HOME/.nvm"
export ZSH="$HOME/.oh-my-zsh"
export EDITOR="nano"
export TSH_DIR="$HOME/.terminally-chill-shell"

# Lazy-load nvm: only sources nvm on first use of nvm/node/npm/npx/yarn.
# Each wrapper is self-contained so it works in subshells where _load_nvm
# might not be inherited.
#
# SC1091 is disabled throughout because nvm.sh is an external runtime file
# installed in the user's home directory — shellcheck cannot follow it at
# lint time and there is no workaround.
# shellcheck disable=SC1091
_load_nvm() {
  unset -f _load_nvm nvm node npm npx yarn
  [ -s "${NVM_DIR:-$HOME/.nvm}/nvm.sh" ] && \. "${NVM_DIR:-$HOME/.nvm}/nvm.sh"
  [ -s "${NVM_DIR:-$HOME/.nvm}/bash_completion" ] && \. "${NVM_DIR:-$HOME/.nvm}/bash_completion"
}
# shellcheck disable=SC1091
nvm()  { _load_nvm 2>/dev/null || { unset -f nvm node npm npx yarn; [ -s "${NVM_DIR:-$HOME/.nvm}/nvm.sh" ] && \. "${NVM_DIR:-$HOME/.nvm}/nvm.sh"; }; nvm "$@"; }
# shellcheck disable=SC1091
node() { _load_nvm 2>/dev/null || { unset -f nvm node npm npx yarn; [ -s "${NVM_DIR:-$HOME/.nvm}/nvm.sh" ] && \. "${NVM_DIR:-$HOME/.nvm}/nvm.sh"; }; command node "$@"; }
# shellcheck disable=SC1091
npm()  { _load_nvm 2>/dev/null || { unset -f nvm node npm npx yarn; [ -s "${NVM_DIR:-$HOME/.nvm}/nvm.sh" ] && \. "${NVM_DIR:-$HOME/.nvm}/nvm.sh"; }; command npm "$@"; }
# shellcheck disable=SC1091
npx()  { _load_nvm 2>/dev/null || { unset -f nvm node npm npx yarn; [ -s "${NVM_DIR:-$HOME/.nvm}/nvm.sh" ] && \. "${NVM_DIR:-$HOME/.nvm}/nvm.sh"; }; command npx "$@"; }
# shellcheck disable=SC1091
yarn() { _load_nvm 2>/dev/null || { unset -f nvm node npm npx yarn; [ -s "${NVM_DIR:-$HOME/.nvm}/nvm.sh" ] && \. "${NVM_DIR:-$HOME/.nvm}/nvm.sh"; }; command yarn "$@"; }
