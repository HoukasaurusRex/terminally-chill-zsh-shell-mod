function tch                # Show a list of functions
{
  printf '\n'
  echo "${BOLD}" 'FUNCTIONS ===============================>'
  echo "${RESET}"
  grep "^function" "$HOME/.functions"
  echo "${RESET}"
  echo "${BOLD}" 'ALIASES   ===============================>'
  echo "${RESET}"
  grep "^alias" "$HOME/.aliases"
}

function gitignore          # Generate gitignore
{
  npx gitignore "$1"
}

function listening          # Check Ports
{
  if [ $# -eq 0 ]; then
    sudo lsof -iTCP -sTCP:LISTEN -n -P
  elif [ $# -eq 1 ]; then
    sudo lsof -iTCP -sTCP:LISTEN -n -P | grep -i --color "$1"
  else
    echo 'Usage: listening [pattern]'
  fi
}

function damn               # Reinstall node_modules
{
  if [ "$1" ]; then
    if [[ "$1" == 'yarn' ]]; then
      rm -rf node_modules
      yarn install
    elif [[ "$1" == 'npm' ]]; then
      rm -rf node_modules
      npm install
    else
      echo "Usage: damn [${YELLOW} yarn ${RESET} | ${YELLOW} npm ${RESET}]"
    fi
  else
    if command -v yarn &>/dev/null; then
      rm -rf node_modules
      yarn install
    else
      rm -rf node_modules
      npm install
    fi
  fi
}

function untrack            # Fix untracked files in git
{
  git rm -r --cached .
  git add .
  git commit -m 'fixed untracked files'
}

function fromhex            # Converts hexadecimal color code to tput color index
{
    hex=${1#"#"}
    r=$(printf '0x%0.2s' "$hex")
    g=$(printf '0x%0.2s' "${hex#??}")
    b=$(printf '0x%0.2s' "${hex#????}")
    printf '%03d' "$(( (r<75?0:(r-35)/40)*6*6 +
                       (g<75?0:(g-35)/40)*6   +
                       (b<75?0:(b-35)/40)     + 16 ))"
}

function upgrade            # Upgrades shell profiles to latest release
{
  if [ -f "$ZSH/tools/upgrade.sh" ]; then
    sh "$ZSH/tools/upgrade.sh"
  else
    omz update
  fi
}

function mkcd               # Make directory and immediately cd into it
{
  if [ ! -n "$1" ]; then
    echo "Usage: mkcd [directory-name]"
  elif [ -d "$1" ]; then
    echo "\`$1' already exists"
  else
    mkdir "$1" && cd "$1" || return
  fi
}

function retry_command       # Retry a command up to 3 times before failing
{
  local retries="${RETRY_COUNT:-3}"
  local attempt=1
  while [ "$attempt" -le "$retries" ]; do
    if "$@"; then
      return 0
    fi
    printf "Attempt %d/%d failed. " "$attempt" "$retries"
    attempt=$((attempt + 1))
    if [ "$attempt" -le "$retries" ]; then
      printf "Retrying...\n"
    else
      printf "Giving up.\n"
    fi
  done
  return 1
}

function show-hidden-files  # Show hidden files in Finder
{
  defaults write com.apple.finder AppleShowAllFiles YES; killall Finder
}

function mcp-add             # Add MCP server to ~/.mcp-servers.json
{
  local mcp_file="${HOME}/.mcp-servers.json"

  if ! command -v jq &>/dev/null; then
    echo "${YELLOW}jq is required. Install with: brew install jq${RESET}"
    return 1
  fi

  if [[ ! -f "${mcp_file}" ]]; then
    echo '{"mcpServers":{}}' > "${mcp_file}"
  fi

  # JSON mode — accept arg, file path, stdin pipe, or clipboard
  local input=""
  if [[ $# -gt 0 ]]; then
    input="$1"
    if [[ -f "${input}" ]]; then
      input=$(cat "${input}")
    fi
  elif [[ ! -t 0 ]]; then
    input=$(cat)
  fi

  if [[ -n "${input}" ]]; then
    local servers
    # Accept {"mcpServers": {...}} or bare {"name": {"command": ...}}
    servers=$(echo "${input}" | jq -e '.mcpServers // empty' 2>/dev/null)
    if [[ -z "${servers}" ]]; then
      # Try bare format: wrap if every value has a "command" key
      servers=$(echo "${input}" | jq -e 'if all(.[]; has("command")) then . else empty end' 2>/dev/null)
    fi
    if [[ -z "${servers}" ]]; then
      echo "${YELLOW}Invalid JSON. Expected format:${RESET}"
      echo '  {"mcpServers": {"name": {"command": "...", "args": [...]}}}'
      echo "${YELLOW}or bare:${RESET}"
      echo '  {"name": {"command": "...", "args": [...]}}'
      return 1
    fi
    local tmp_file
    tmp_file=$(mktemp)
    jq --argjson new "${servers}" '.mcpServers += $new' "${mcp_file}" > "${tmp_file}" && mv "${tmp_file}" "${mcp_file}"
    echo "${GREEN}Added to ${mcp_file}:${RESET}"
    echo "${servers}" | jq -r 'keys[]' | while read -r n; do echo "  ${GREEN}+${RESET} ${n}"; done
  else
    # Guided mode
    local name cmd args_str
    printf "%s" "${BOLD}Server name: ${RESET}"
    read -r name
    if [[ -z "${name}" ]]; then
      echo "${YELLOW}Name is required${RESET}"
      return 1
    fi
    printf "%s" "${BOLD}Command${RESET} (e.g. npx, python, node): "
    read -r cmd
    if [[ -z "${cmd}" ]]; then
      echo "${YELLOW}Command is required${RESET}"
      return 1
    fi
    printf "%s" "${BOLD}Args${RESET} (space-separated, e.g. -y @scope/pkg): "
    read -r args_str
    printf "%s\n" "${BOLD}Env vars${RESET} (KEY=VALUE per line, empty to finish):"
    local env_json="{}"
    while true; do
      local kv
      printf "  "
      read -r kv
      if [[ -z "${kv}" ]]; then
        break
      fi
      local key="${kv%%=*}"
      local val="${kv#*=}"
      env_json=$(echo "${env_json}" | jq --arg k "${key}" --arg v "${val}" '. + {($k): $v}')
    done

    local args_json="[]"
    if [[ -n "${args_str}" ]]; then
      args_json=$(echo "${args_str}" | jq -R 'split(" ") | map(select(. != ""))')
    fi

    local server_json
    server_json=$(jq -n --arg cmd "${cmd}" --argjson args "${args_json}" --argjson env "${env_json}" \
      'if $env == {} then {command: $cmd, args: $args} else {command: $cmd, args: $args, env: $env} end')

    local tmp_file
    tmp_file=$(mktemp)
    jq --arg name "${name}" --argjson server "${server_json}" '.mcpServers[$name] = $server' "${mcp_file}" > "${tmp_file}" && mv "${tmp_file}" "${mcp_file}"
    echo "${GREEN}Added ${name} to ${mcp_file}${RESET}"
  fi
}

function mcp-remove          # Remove MCP server from ~/.mcp-servers.json
{
  local mcp_file="${HOME}/.mcp-servers.json"

  if ! command -v jq &>/dev/null; then
    echo "${YELLOW}jq is required. Install with: brew install jq${RESET}"
    return 1
  fi

  if [[ ! -f "${mcp_file}" ]]; then
    echo "${YELLOW}No MCP servers configured.${RESET}"
    return 1
  fi

  if [[ -z "$1" ]]; then
    echo "Usage: mcp-remove <server-name>"
    return 1
  fi

  if ! jq -e --arg name "$1" '.mcpServers[$name]' "${mcp_file}" &>/dev/null; then
    echo "${YELLOW}Server '$1' not found.${RESET}"
    return 1
  fi

  local tmp_file
  tmp_file=$(mktemp)
  jq --arg name "$1" 'del(.mcpServers[$name])' "${mcp_file}" > "${tmp_file}" && mv "${tmp_file}" "${mcp_file}"
  echo "${GREEN}Removed $1 from ${mcp_file}${RESET}"
}

function mcp-list            # List MCP servers in ~/.mcp-servers.json
{
  local mcp_file="${HOME}/.mcp-servers.json"

  if ! command -v jq &>/dev/null; then
    echo "${YELLOW}jq is required. Install with: brew install jq${RESET}"
    return 1
  fi

  if [[ ! -f "${mcp_file}" ]] || [[ "$(jq '.mcpServers | length' "${mcp_file}")" -eq 0 ]]; then
    echo "${YELLOW}No MCP servers configured. Run ${BOLD}mcp-add${RESET}${YELLOW} to add one.${RESET}"
    return 0
  fi

  echo "${BOLD}MCP Servers (${mcp_file}):${RESET}"
  jq -r '.mcpServers | to_entries[] | "  \(.key)\t\(.value.command) \(.value.args | join(" "))"' "${mcp_file}" | column -t -s $'\t'
}

function mcp-init            # Init MCP servers in current project from ~/.mcp-servers.json
{
  local mcp_file="${HOME}/.mcp-servers.json"
  local settings_dir=".claude"
  local settings_file="${settings_dir}/settings.json"
  local claude_md="CLAUDE.md"

  if ! command -v jq &>/dev/null; then
    echo "${YELLOW}jq is required. Install with: brew install jq${RESET}"
    return 1
  fi

  if [[ ! -f "${mcp_file}" ]] || [[ "$(jq '.mcpServers | length' "${mcp_file}")" -eq 0 ]]; then
    echo "${YELLOW}No MCP servers configured. Run ${BOLD}mcp-add${RESET}${YELLOW} first.${RESET}"
    return 1
  fi

  local server_count
  server_count=$(jq '.mcpServers | length' "${mcp_file}")

  # Step 1 — Ensure .claude directory exists
  mkdir -p "${settings_dir}"

  # Step 2 — Create or merge .claude/settings.json
  if [[ ! -f "${settings_file}" ]]; then
    cp "${mcp_file}" "${settings_file}"
    echo "${GREEN}Created ${settings_file} with ${server_count} server(s)${RESET}"
  else
    local tmp_file
    tmp_file=$(mktemp)
    jq --slurpfile dotfile "${mcp_file}" \
      '.mcpServers = ((.mcpServers // {}) + $dotfile[0].mcpServers)' \
      "${settings_file}" > "${tmp_file}" && mv "${tmp_file}" "${settings_file}"
    echo "${GREEN}Merged ${server_count} server(s) into ${settings_file}${RESET}"
  fi

  # Step 3 — Add jt-mcp section to CLAUDE.md (if jt-mcp is configured)
  if jq -e '.mcpServers["jt-mcp"]' "${mcp_file}" &>/dev/null; then
    local jt_mcp_section
    jt_mcp_section=$(cat <<'EOF'

## MCP Tools (`@houkasaurusrex/jt-mcp-server`)

This project has the following MCP tool categories available. Tools may be deferred — search for them by prefix when needed.

| Prefix | Tools | Purpose |
|--------|-------|---------|
| `dev_` | dev_run, dev_port, dev_serve, dev_install, dev_script, dev_deps, dev_worktree, dev_visual_regression | Dev workflow (run commands, manage ports, install deps) |
| `dev_` | dev_grep, dev_find, dev_read, dev_tree | Search & explore files |
| `git_` | git_conventional_commit | Conventional commits |
| `github_` | github_create_pr, github_project_next_issue, github_project_set_status, github_project_complete_issue | GitHub PRs & project boards |
| `jira_` | jira_search, jira_get_issue, jira_create_issue, jira_transition, jira_add_comment, jira_assign | Jira issue management (requires `acli auth login`) |
| `confluence_` | confluence_search, confluence_get_page, confluence_create_page, confluence_update_page | Confluence pages (requires ATLASSIAN_* env vars) |
| `netlify_` | netlify_deploy_status, netlify_build_log, netlify_function_log, netlify_list_deploys, netlify_list_functions | Netlify deploys & functions |
| `memory_` | memory_query, memory_add_entities, memory_add_relations, memory_add_observations, memory_delete, memory_export, memory_import | Persistent knowledge graph |

### Memory

At the start of every session:
1. Call `memory_query` with no filters to load all stored context
2. Use the returned entities, observations, and relations to inform your work
3. When you learn new user preferences or project conventions, store them with `memory_add_entities` and `memory_add_observations`
EOF
    )

    if [[ ! -f "${claude_md}" ]]; then
      printf "# CLAUDE.md\n%s\n" "${jt_mcp_section}" > "${claude_md}"
      echo "${GREEN}Created ${claude_md} with MCP tools section${RESET}"
    elif grep -q '## MCP Tools' "${claude_md}"; then
      echo "${YELLOW}MCP Tools section already exists in ${claude_md}${RESET}"
    else
      # Remove old Memory-only section if present, replace with full section
      if grep -q '## Memory' "${claude_md}"; then
        local tmp_file
        tmp_file=$(mktemp)
        sed '/^## Memory$/,/^## /{ /^## Memory$/d; /^## /!d; }' "${claude_md}" > "${tmp_file}" && mv "${tmp_file}" "${claude_md}"
      fi
      printf "%s\n" "${jt_mcp_section}" >> "${claude_md}"
      echo "${GREEN}Appended MCP tools section to ${claude_md}${RESET}"
    fi
  fi

  # Step 4 — Env var warnings
  jq -r '[.mcpServers[].env // {} | values[]] | unique[]' "${mcp_file}" 2>/dev/null | \
    sed -n 's/^\${\(.*\)}$/\1/p' | while read -r var_name; do
    if ! printenv "${var_name}" &>/dev/null; then
      echo "${YELLOW}${BOLD}Warning:${RESET}${YELLOW} ${var_name} is not set${RESET}"
    fi
  done

  echo "${GREEN}${BOLD}MCP servers initialized!${RESET}"
  jq -r '.mcpServers | keys[]' "${mcp_file}" | while read -r name; do
    echo "  ${GREEN}+${RESET} ${name}"
  done
}
